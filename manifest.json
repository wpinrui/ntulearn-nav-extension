{
  "manifest_version": 3,
  "name": "NTUitive",
  "version": "2.0.1",
  "description": "A smarter NTULearn experience — course switcher, folder expansion, download buttons, dark theme, and more.",
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "ntuitive@wpinrui",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://ntulearn.ntu.edu.sg/*"],
      "js": ["defaults.js", "bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://ntulearn.ntu.edu.sg/*"],
      "js": ["settings.js", "darktheme.js", "content.js", "courses.js", "courselinks.js", "outline.js", "viewer.js", "download.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
